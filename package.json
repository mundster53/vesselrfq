    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "drizzle-orm": "^0.40.1",
    "jose": "^5.10.0",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.4.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@vercel/node": "^5.1.4",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "express": "^5.2.1",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.1"
