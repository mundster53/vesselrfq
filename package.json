{
  "name": "vesselrfq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:vite\" --names api,vite --prefix-colors cyan,green",
    "dev:vite": "vite",
    "dev:server": "tsx watch --env-file=.env.local server/dev.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
