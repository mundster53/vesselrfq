{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/fabricators", "destination": "/fabricators/index.html" },
    { "source": "/fabricators/success", "destination": "/fabricators/success.html" },
    { "source": "/fabricators/embed-guide", "destination": "/fabricators/embed-guide.html" },
    { "source": "/fabricators/demo", "destination": "/fabricators/demo.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-verify-embeds",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron-close-rfqs",
      "schedule": "0 6 * * *"
    }
  ]
}
